# Flask Environment Configuration
# Copy this to .env and set appropriate values for your deployment

# Development or Production mode
# Set to "development" for debug mode, "production" for production
FLASK_ENV=development

# Flask App
FLASK_APP=app.py

# For production deployments, you may need to set CORS allowed origins
# CORS_ORIGINS=https://yourdomain.com

# Backend Port
# BACKEND_PORT=5000
